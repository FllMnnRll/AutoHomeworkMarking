# Copy to .env and fill in values. Never commit .env to git.

# Master key for decrypting enc: secrets (generate with: npm run encrypt:generate-key)
SECRETS_ENCRYPTION_KEY=

# --- AI API Keys (use enc: values from: npm run encrypt:secret -- "your-key") ---
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
# Optional: comma-separated fallback Gemini keys
GEMINI_API_KEYS=

# --- Optional AI settings ---
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL_NAME=MiniMax-Text-01
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Database ---
DATABASE_URL="file:./prisma/dev.db"

# --- Email scan (optional) ---
# IMAP_USER=
# IMAP_PASS=
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993

# --- Grading tuning (optional) ---
# GRADING_CONCURRENCY=3
# PDF_RASTER_SCALE=2.0
# JPEG quality of rasterized PDF pages, 0.5-1.0 (default 0.85; lower = smaller OCR payload)
# PDF_JPEG_QUALITY=0.85
# How many PDF pages are rendered concurrently, 1-8 (default 4)
# PDF_RASTER_CONCURRENCY=4
# CROSS_VAL_PROB=0.25
# PDF_CHUNK_PARALLEL_WORKERS=2
# USE_MOCK_OCR=false

# --- Proxy (optional) ---
# HTTPS_PROXY=
# HTTP_PROXY=
